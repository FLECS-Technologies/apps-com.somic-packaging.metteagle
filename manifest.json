{
    "$schema": "https://raw.githubusercontent.com/FLECS-Technologies/app-sdk/main/manifest.schema.json",
    "_schemaVersion": "2.0.0",
    "app": "com.somic-packaging.metteagle",
    "version": "##VERSION##",
    "revision": "0",
    "image": "flecs.azurecr.io/com.somic-packaging.metteagle",
    "multiInstance": false,
    "editor": ":8080",
    "ports": [
        "8081:8080"
    ],
    "volumes": [
        "/home/somic/app/metteagle/:/metteagle"
    ],
    "env": [
        "VideoFileLocation=/metteagle/assets",
        "ApplicationSettingsPath=/metteagle/metteagle.yaml",
        "ConnectionStrings__SQLiteDefault=DataSource=/metteagle/metteagle.db",
        "MetteagleLocation=/metteagle/",
        "Kiosk__LauncherEnabled=false",
        "CameraType=SEC100",
        "NotificationApi__BaseUrl=http://localhost:5222",
        "authFreeTrigger=false",
        "UseTcpTrigger=false"
    ]
}
